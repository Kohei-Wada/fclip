{
  "name": "fclip",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "scripts": {
    "dev": "tauri dev",
    "build": "tauri build",
    "build:nobundle": "tauri build --no-bundle",
    "check": "cargo check --manifest-path src-tauri/Cargo.toml",
    "test": "cargo test --lib --manifest-path src-tauri/Cargo.toml",
    "test:front": "vitest run",
    "lint": "cargo clippy --manifest-path src-tauri/Cargo.toml && tsc --noEmit",
    "clean": "cargo clean --manifest-path src-tauri/Cargo.toml",
    "tauri": "tauri",
    "vite": "vite",
    "vite:build": "tsc && vite build",
    "prepare": "husky",
    "bump": "node scripts/bump-version.mjs",
    "changelog": "npx git-cliff --output CHANGELOG.md"
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "src/**/*.css": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tauri-apps/cli": "^2",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "eslint": "^10.1.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.57.1",
    "vite": "^7.0.4",
    "vitest": "^4.1.1"
  }
}
